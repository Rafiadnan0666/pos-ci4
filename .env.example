#--------------------------------------------------------------------
# Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
#   development - Shows errors, debug toolbar enabled
#   production  - Hides errors, debug toolbar disabled, optimized
#--------------------------------------------------------------------
CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'http://localhost:8080/'
app.storeName = 'Your Store Name'
app.storeAddress = 'Your Store Address'
app.storePhone = '02123456789'

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = pos-ci4
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

database.tests.hostname = localhost
database.tests.database = pos-ci4
database.tests.username = root
database.tests.password =

#--------------------------------------------------------------------
# ENCRYPTION KEY
#--------------------------------------------------------------------
# Generate a key: php spark key:generate
# Format: hex2bin:<64_hex_chars>
#--------------------------------------------------------------------
encryption.key = hex2bin:f0aa2f095c74624c68dfd1eb3051c981f15160e125723d0068bf0e75c5bc6796

#--------------------------------------------------------------------
# MIDTRANS PAYMENT GATEWAY
#--------------------------------------------------------------------
# Get keys from https://dashboard.midtrans.com/
# Sandbox keys start with SB-Mid-
# Production keys start with Mid-
#--------------------------------------------------------------------
MIDTRANS_CLIENT_KEY=SB-Mid-client-your_client_key
MIDTRANS_SERVER_KEY=SB-Mid-server-your_server_key
MIDTRANS_IS_PRODUCTION=false

#--------------------------------------------------------------------
# BITESHIP SHIPPING
#--------------------------------------------------------------------
# Get API key from https://dashboard.biteship.com/
# Test keys start with biteship_test.
# Live keys start with biteship_live.
#--------------------------------------------------------------------
BITESHIP_API_KEY=biteship_test.your_api_key

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------
# session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
# session.savePath = null

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------
# logger.threshold = 4
